{
  "name": "codex-scheduler",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Codex scheduler for repository automation with Linear intake, verification loops, and delivery workflows.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "keywords": [
    "codex",
    "openai",
    "scheduler",
    "automation",
    "linear",
    "github",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm lint && pnpm test && pnpm build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "lint": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@linear/sdk": "^78.0.0",
    "@octokit/rest": "^22.0.1",
    "@openai/codex": "^0.116.0",
    "@openai/codex-sdk": "^0.116.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "openai": "^6.35.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
