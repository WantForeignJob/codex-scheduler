{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "drizzle.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
